---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'];
const { title, description, pubDate, updatedDate, heroImage } = Astro.props;
---
<html lang="en">
  <head>
    <BaseHead title={title} description={description} />
  </head>
  <body>
    <Header />

    <main>
      <article class="article-wrap">

        <!-- Hero image -->
        {heroImage && (
          <div class="hero-image-wrap">
            <Image width={1020} height={510} src={heroImage} alt={title} class="hero-img" />
            <div class="hero-img-overlay"></div>
          </div>
        )}

        <!-- Article header -->
        <header class="article-header">
          <div class="article-meta">
            <span class="meta-date">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
                <line x1="16" y1="2" x2="16" y2="6"></line>
                <line x1="8" y1="2" x2="8" y2="6"></line>
                <line x1="3" y1="10" x2="21" y2="10"></line>
              </svg>
              <FormattedDate date={pubDate} />
            </span>
            {updatedDate && (
              <span class="meta-updated">
                Updated: <FormattedDate date={updatedDate} />
              </span>
            )}
          </div>
          <h1 class="article-title">{title}</h1>
          {description && <p class="article-description">{description}</p>}
          <div class="article-divider"></div>
        </header>

        <!-- Prose content -->
        <div class="prose">
          <slot />
        </div>

        <!-- Back link -->
        <div class="back-link-wrap">
          <a href="/blog" class="back-link">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
              <line x1="19" y1="12" x2="5" y2="12"></line>
              <polyline points="12 19 5 12 12 5"></polyline>
            </svg>
            Back to all articles
          </a>
        </div>

      </article>
    </main>

    <Footer />
  </body>
</html>

<style>
  /* ── Layout ──────────────────────────────────────────────────────────────── */
  main {
    max-width: 800px;
    width: calc(100% - 2em);
    margin: 0 auto;
    padding: 2.5em 1em 4em;
    position: relative;
    z-index: 1;
  }

  .article-wrap {
    position: relative;
  }

  /* ── Hero image ──────────────────────────────────────────────────────────── */
  .hero-image-wrap {
    position: relative;
    border-radius: 20px;
    overflow: hidden;
    margin-bottom: 2.5em;
    box-shadow:
      0 0 0 1px rgba(0, 212, 255, 0.15),
      0 8px 40px rgba(0, 0, 0, 0.5),
      0 0 60px rgba(0, 212, 255, 0.08);
  }

  .hero-img {
    display: block;
    width: 100%;
    height: auto;
    border-radius: 0;
    transition: transform 0.6s ease;
  }

  .hero-image-wrap:hover .hero-img {
    transform: scale(1.02);
  }

  .hero-img-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      transparent 50%,
      rgba(2, 11, 24, 0.6) 100%
    );
    pointer-events: none;
  }

  /* ── Article header ──────────────────────────────────────────────────────── */
  .article-header {
    margin-bottom: 2.5em;
  }

  .article-meta {
    display: flex;
    align-items: center;
    gap: 1.5em;
    flex-wrap: wrap;
    margin-bottom: 1em;
  }

  .meta-date {
    display: inline-flex;
    align-items: center;
    gap: 0.4em;
    font-size: 0.82rem;
    color: rgba(0, 212, 255, 0.75);
    font-weight: 500;
    letter-spacing: 0.03em;
  }

  .meta-updated {
    font-size: 0.78rem;
    color: rgba(138, 180, 204, 0.55);
    font-style: italic;
  }

  .article-title {
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    font-weight: 900;
    line-height: 1.15;
    color: #e8f4fd;
    margin-bottom: 0.6em;
    letter-spacing: -0.025em;
  }

  .article-description {
    font-size: 1.05rem;
    color: rgba(138, 180, 204, 0.8);
    line-height: 1.65;
    margin: 0 0 1.5em;
    font-style: italic;
    border-left: 3px solid rgba(0, 212, 255, 0.4);
    padding-left: 1em;
  }

  .article-divider {
    height: 1px;
    background: linear-gradient(90deg, rgba(0, 212, 255, 0.5), rgba(0, 255, 157, 0.3), transparent);
    margin-top: 1.5em;
  }

  /* ── Prose ───────────────────────────────────────────────────────────────── */
  .prose {
    font-size: 1.05rem;
    line-height: 1.85;
    color: rgba(220, 238, 252, 0.88);
  }

  .prose :global(h2) {
    font-size: 1.7rem;
    margin-top: 2.5em;
    margin-bottom: 0.75em;
    padding-bottom: 0.4em;
    border-bottom: 1px solid rgba(0, 212, 255, 0.15);
    color: #e8f4fd;
  }

  .prose :global(h3) {
    font-size: 1.35rem;
    margin-top: 2em;
    margin-bottom: 0.6em;
    color: #c8e8f8;
  }

  .prose :global(h4) {
    font-size: 1.1rem;
    margin-top: 1.5em;
    color: rgba(0, 212, 255, 0.9);
  }

  .prose :global(a) {
    color: #00d4ff;
    text-decoration: underline;
    text-decoration-color: rgba(0, 212, 255, 0.35);
    text-underline-offset: 3px;
    transition: all 0.2s ease;
  }

  .prose :global(a:hover) {
    color: #00ff9d;
    text-decoration-color: rgba(0, 255, 157, 0.5);
    text-shadow: 0 0 10px rgba(0, 255, 157, 0.3);
  }

  .prose :global(ul),
  .prose :global(ol) {
    padding-left: 1.5em;
    margin-bottom: 1.5em;
  }

  .prose :global(li) {
    margin-bottom: 0.4em;
  }

  .prose :global(li::marker) {
    color: rgba(0, 212, 255, 0.6);
  }

  .prose :global(img) {
    border-radius: 12px;
    border: 1px solid rgba(0, 212, 255, 0.12);
    box-shadow: 0 4px 20px rgba(0,0,0,0.4);
    margin: 1.5em auto;
    display: block;
  }

  .prose :global(table) {
    margin: 1.5em 0;
    border-radius: 10px;
    overflow: hidden;
  }

  /* ── Back link ───────────────────────────────────────────────────────────── */
  .back-link-wrap {
    margin-top: 3.5em;
    padding-top: 2em;
    border-top: 1px solid rgba(0, 212, 255, 0.10);
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5em;
    font-size: 0.9rem;
    font-weight: 600;
    color: rgba(0, 212, 255, 0.7);
    text-decoration: none;
    padding: 0.5em 1.2em;
    border-radius: 8px;
    border: 1px solid rgba(0, 212, 255, 0.18);
    background: rgba(0, 212, 255, 0.04);
    transition: all 0.22s ease;
  }

  .back-link:hover {
    color: #00d4ff;
    border-color: rgba(0, 212, 255, 0.4);
    background: rgba(0, 212, 255, 0.08);
    box-shadow: 0 0 16px rgba(0, 212, 255, 0.2);
    text-shadow: none;
    transform: translateX(-3px);
  }

  /* ── Responsive ──────────────────────────────────────────────────────────── */
  @media (max-width: 720px) {
    main { padding: 1.5em 1em 3em; }
    .article-title { font-size: 1.7rem; }
    .hero-image-wrap { border-radius: 14px; }
  }
</style>
