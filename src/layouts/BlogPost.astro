---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import AdBanner from '../components/AdBanner.astro';

type Props = CollectionEntry<'blog'>['data'];
const { title, description, pubDate, updatedDate, image } = Astro.props;
---
<html lang="en">
  <head>
    <BaseHead title={title} description={description} />
    <style>
      main {
        max-width: 720px;
        width: calc(100% - 3rem);
        margin: 0 auto;
        padding: 6rem 0;
      }
      .back-link {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        color: #4F46E5;
        font-weight: 600;
        text-decoration: none;
        margin-bottom: 3rem;
        transition: all 0.2s ease;
        font-size: 0.95rem;
      }
      .back-link:hover {
        color: #4338CA;
        transform: translateX(-4px);
      }
      .hero-img {
        width: 100%;
        border-radius: 16px;
        margin-bottom: 4rem;
        box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.05);
        border: 1px solid rgba(0, 0, 0, 0.04);
      }
      .article-header {
        margin-bottom: 4rem;
        text-align: left;
      }
      .article-date {
        color: #4F46E5;
        font-weight: 600;
        margin-bottom: 1rem;
        font-size: 1rem;
      }
      .article-title {
        font-size: 3rem;
        font-weight: 800;
        color: #1A1A1A;
        line-height: 1.15;
        letter-spacing: -0.03em;
      }
      .prose {
        font-size: 1.125rem;
        color: #2D3748;
        line-height: 1.8;
      }
      @media (max-width: 720px) {
        .article-title { font-size: 2.25rem; }
        main { padding: 4rem 0; }
        .hero-img { margin-bottom: 2.5rem; }
      }
    </style>
  </head>
  <body>
    <Header />
    <main>
      <a href="/blog" class="back-link">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"></line><polyline points="12 19 5 12 12 5"></polyline></svg>
        Back to archive
      </a>
      <article>
        {image && <img src={image} alt="" class="hero-img" loading="eager" />}
        
        <!-- Position 1: Below hero image / above header -->
        <AdBanner minHeight="250px" margin="0 0 40px 0" />

        <header class="article-header">
          <div class="article-date">
            <FormattedDate date={pubDate} />
            {updatedDate && <span> (Updated: <FormattedDate date={updatedDate} />)</span>}
          </div>
          <h1 class="article-title">{title}</h1>
        </header>

        <div class="prose" id="article-content">
          <slot />
        </div>

        <!-- Position 3: Bottom of article -->
        <AdBanner minHeight="250px" margin="40px 0 0 0" />
      </article>
    </main>

    <!-- Mid-article dynamic injection script -->
    <script is:inline>
      document.addEventListener('DOMContentLoaded', () => {
        const prose = document.getElementById('article-content');
        if (!prose) return;
        
        const paragraphs = prose.querySelectorAll('p');
        if (paragraphs.length >= 4) {
          const midIndex = Math.floor(paragraphs.length / 2);
          const target = paragraphs[midIndex];
          
          const adContainer = document.createElement('div');
          adContainer.className = 'ad-container';
          adContainer.style.minHeight = '250px';
          adContainer.style.margin = '40px auto';
          adContainer.style.display = 'flex';
          adContainer.style.justifyContent = 'center';
          adContainer.style.alignItems = 'center';
          adContainer.style.width = '100%';
          adContainer.style.background = 'rgba(0, 0, 0, 0.02)';
          adContainer.style.borderRadius = '8px';
          adContainer.style.overflow = 'hidden';

          // Inject Adsterra Native Banner code
          const script = document.createElement('script');
          script.async = true;
          script.dataset.cfasync = "false";
          script.src = "https://pl29385882.effectivecpmnetwork.com/9443ced55ad6dc338cd7a9fec5677f94/invoke.js";
          
          const div = document.createElement('div');
          div.id = 'container-9443ced55ad6dc338cd7a9fec5677f94';
          
          adContainer.appendChild(script);
          adContainer.appendChild(div);
          
          target.parentNode.insertBefore(adContainer, target);
        }
      });
    </script>

    <Footer />
  </body>
</html>
