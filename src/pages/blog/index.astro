---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import AdBanner from '../../components/AdBanner.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---
<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={`Blog — ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
    <style>
      .page-header {
        padding: 6rem 1.5rem 4rem;
        text-align: center;
        background: #FFFFFF;
        border-bottom: 1px solid rgba(0, 0, 0, 0.04);
      }
      .page-title {
        font-size: 3rem;
        font-weight: 800;
        color: #1A1A1A;
        margin-bottom: 1rem;
        letter-spacing: -0.02em;
      }
      .page-subtitle {
        color: #4A5568;
        font-size: 1.15rem;
        max-width: 600px;
        margin: 0 auto;
      }

      main {
        max-width: 1000px;
        margin: 5rem auto;
        padding: 0 1.5rem;
      }

      .posts-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 3rem;
      }

      .post-card {
        text-decoration: none;
        transition: all 0.3s ease;
        display: flex;
        flex-direction: column;
      }
      .post-card:hover { transform: translateY(-5px); }
      
      .card-img {
        width: 100%;
        height: 240px;
        object-fit: cover;
        border-radius: 12px;
        margin-bottom: 1.5rem;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
        border: 1px solid rgba(0, 0, 0, 0.04);
      }
      .post-card:hover .card-img {
        box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.08);
      }

      .card-date {
        font-size: 0.875rem;
        color: #4F46E5;
        font-weight: 600;
        margin-bottom: 0.75rem;
      }
      .card-title {
        font-size: 1.5rem;
        color: #1A1A1A;
        margin-bottom: 1rem;
        line-height: 1.3;
        font-weight: 700;
      }
      .card-desc {
        font-size: 1rem;
        color: #4A5568;
        line-height: 1.6;
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow: hidden;
      }

      @media (max-width: 900px) {
        .posts-grid { grid-template-columns: repeat(2, 1fr); gap: 2.5rem; }
      }
      @media (max-width: 600px) {
        .posts-grid { grid-template-columns: 1fr; }
        .page-title { font-size: 2.5rem; }
        .page-header { padding: 4rem 1.5rem 3rem; }
      }
    </style>
  </head>
  <body>
    <Header />
    <AdBanner minHeight="90px" margin="0 auto 20px" />
    <section class="page-header">
      <h1 class="page-title">The Archive</h1>
      <p class="page-subtitle">A collection of deep dives into the future of technology and artificial intelligence.</p>
    </section>
    <main>
      <div class="posts-grid">
        {posts.map((post) => (
          <a href={`/blog/${post.id}/`} class="post-card">
            <img src={post.data.heroImage || '/blog-placeholder-about.jpg'} alt="" class="card-img" />
            <div class="card-body">
              <p class="card-date"><FormattedDate date={post.data.pubDate} /></p>
              <h3 class="card-title">{post.data.title}</h3>
              <p class="card-desc">{post.data.description}</p>
            </div>
          </a>
        ))}
      </div>
    <AdBanner minHeight="250px" margin="40px auto" />
    </main>
    <Footer />
  </body>
</html>
