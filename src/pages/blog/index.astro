---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---
<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={`Blog — ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
    <style>
      .page-hero {
        padding: 5rem 1rem;
        text-align: center;
        background: #f8fafc;
        border-bottom: 1px solid rgba(16, 185, 129, 0.1);
      }
      .page-title {
        font-size: 3rem;
        font-weight: 800;
        color: #0f172a;
        margin-bottom: 0.5rem;
      }
      .page-subtitle {
        color: #64748b;
        font-size: 1.1rem;
      }

      main {
        max-width: 1100px;
        margin: 4rem auto;
        padding: 0 1.5rem;
      }

      .posts-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 2.5rem;
      }

      .post-card {
        text-decoration: none;
        transition: all 0.3s ease;
      }
      .post-card:hover { transform: translateY(-5px); }
      
      .card-img {
        width: 100%;
        height: 220px;
        object-fit: cover;
        border-radius: 20px;
        margin-bottom: 1.25rem;
        border: 1px solid #f1f5f9;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
      }
      .post-card:hover .card-img {
        box-shadow: 0 20px 25px -5px rgba(16, 185, 129, 0.1);
      }

      .card-date {
        font-size: 0.85rem;
        color: #10b981;
        font-weight: 600;
        margin-bottom: 0.5rem;
      }
      .card-title {
        font-size: 1.25rem;
        color: #0f172a;
        margin-bottom: 0.75rem;
        line-height: 1.4;
      }
      .card-desc {
        font-size: 0.95rem;
        color: #64748b;
        line-height: 1.6;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
      }

      @media (max-width: 900px) {
        .posts-grid { grid-template-columns: repeat(2, 1fr); }
      }
      @media (max-width: 600px) {
        .posts-grid { grid-template-columns: 1fr; }
        .page-title { font-size: 2.25rem; }
      }
    </style>
  </head>
  <body>
    <Header />
    <section class="page-hero">
      <h1 class="page-title">The Archive</h1>
      <p class="page-subtitle">Deep dives into the future of technology and AI.</p>
    </section>
    <main>
      <div class="posts-grid">
        {posts.map((post) => (
          <a href={`/blog/${post.id}/`} class="post-card">
            <img src={post.data.heroImage || '/blog-placeholder-about.jpg'} alt="" class="card-img" />
            <div class="card-body">
              <p class="card-date"><FormattedDate date={post.data.pubDate} /></p>
              <h3 class="card-title">{post.data.title}</h3>
              <p class="card-desc">{post.data.description}</p>
            </div>
          </a>
        ))}
      </div>
    </main>
    <Footer />
  </body>
</html>
