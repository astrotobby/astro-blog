---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---
<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={`Blog — ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />

    <!-- Page Hero -->
    <div class="page-hero">
      <div class="page-hero-bg"></div>
      <div class="page-hero-content">
        <div class="page-badge">
          <span class="badge-dot"></span>
          All Articles
        </div>
        <h1 class="page-title">The <span class="gradient-text">AstroSignal</span> Blog</h1>
        <p class="page-subtitle">
          {posts.length} articles on AI agents, LLMs, multi-agent systems, and the technologies defining 2026.
        </p>
      </div>
    </div>

    <main>
      <div class="posts-grid">
        {posts.map((post, i) => (
          <a href={`/blog/${post.id}/`} class={`post-card ${i === 0 ? 'post-card--featured' : ''}`}>
            <div class="card-image-wrap">
              {post.data.heroImage ? (
                <Image
                  width={i === 0 ? 900 : 480}
                  height={i === 0 ? 450 : 240}
                  src={post.data.heroImage}
                  alt={post.data.title}
                  class="card-img"
                />
              ) : (
                <div class="card-img-placeholder"></div>
              )}
              <div class="card-img-overlay"></div>
            </div>
            <div class="card-body">
              <p class="card-date">
                <FormattedDate date={post.data.pubDate} />
              </p>
              <h2 class="card-title">{post.data.title}</h2>
              {post.data.description && (
                <p class="card-desc">{post.data.description}</p>
              )}
              <span class="card-cta">Read article →</span>
            </div>
          </a>
        ))}
      </div>
    </main>

    <Footer />
  </body>
</html>

<style>
  /* ── Page Hero ───────────────────────────────────────────────────────────── */
  .page-hero {
    position: relative;
    overflow: hidden;
    padding: 5em 2em 3.5em;
    text-align: center;
    z-index: 1;
  }

  .page-hero-bg {
    position: absolute;
    inset: 0;
    background-image: radial-gradient(circle, rgba(0, 212, 255, 0.10) 1px, transparent 1px);
    background-size: 36px 36px;
    mask-image: radial-gradient(ellipse 70% 80% at 50% 50%, black 20%, transparent 100%);
    pointer-events: none;
  }

  .page-hero-content {
    position: relative;
    z-index: 2;
    max-width: 680px;
    margin: 0 auto;
  }

  .page-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5em;
    padding: 0.3em 1em;
    border-radius: 100px;
    background: rgba(0, 212, 255, 0.07);
    border: 1px solid rgba(0, 212, 255, 0.22);
    font-size: 0.75rem;
    font-weight: 700;
    color: #00d4ff;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 1.2em;
  }

  .badge-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #00d4ff;
    box-shadow: 0 0 8px #00d4ff;
    animation: dotPulse 2s ease-in-out infinite;
  }

  @keyframes dotPulse {
    0%, 100% { box-shadow: 0 0 6px #00d4ff; }
    50%       { box-shadow: 0 0 14px #00d4ff, 0 0 28px rgba(0,212,255,0.4); }
  }

  .page-title {
    font-size: clamp(2rem, 5vw, 3.2rem);
    font-weight: 900;
    margin-bottom: 0.5em;
    color: #e8f4fd;
    line-height: 1.1;
  }

  .gradient-text {
    background: linear-gradient(135deg, #00d4ff 0%, #00ff9d 60%, #00d4ff 100%);
    background-size: 200% 200%;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    animation: gradientShift 5s ease infinite;
  }

  @keyframes gradientShift {
    0%   { background-position: 0% 50%; }
    50%  { background-position: 100% 50%; }
    100% { background-position: 0% 50%; }
  }

  .page-subtitle {
    font-size: 1rem;
    color: rgba(138, 180, 204, 0.75);
    margin: 0;
    line-height: 1.6;
  }

  /* ── Main ────────────────────────────────────────────────────────────────── */
  main {
    max-width: 1100px;
    width: calc(100% - 2em);
    margin: 0 auto;
    padding: 1em 1em 5em;
    position: relative;
    z-index: 1;
  }

  /* ── Grid ────────────────────────────────────────────────────────────────── */
  .posts-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5em;
  }

  /* Featured (first) card spans full width */
  .post-card--featured {
    grid-column: 1 / -1;
    display: grid;
    grid-template-columns: 1.3fr 1fr;
    border-radius: 20px;
  }

  .post-card--featured .card-image-wrap {
    height: 100%;
    min-height: 280px;
  }

  .post-card--featured .card-title {
    font-size: 1.6rem;
    -webkit-line-clamp: 3;
  }

  .post-card--featured .card-desc {
    -webkit-line-clamp: 4;
  }

  .post-card--featured .card-body {
    padding: 2.5em 2em;
    justify-content: center;
  }

  /* ── Card ────────────────────────────────────────────────────────────────── */
  .post-card {
    display: flex;
    flex-direction: column;
    border-radius: 16px;
    overflow: hidden;
    background: rgba(5, 20, 40, 0.65);
    border: 1px solid rgba(0, 212, 255, 0.10);
    text-decoration: none;
    transition: all 0.28s ease;
    box-shadow: 0 2px 20px rgba(0,0,0,0.35);
  }

  .post-card:hover {
    border-color: rgba(0, 212, 255, 0.35);
    box-shadow:
      0 0 0 1px rgba(0, 212, 255, 0.15),
      0 8px 30px rgba(0, 212, 255, 0.12),
      0 16px 40px rgba(0,0,0,0.4);
    transform: translateY(-5px);
  }

  .card-image-wrap {
    position: relative;
    overflow: hidden;
    height: 190px;
    flex-shrink: 0;
  }

  .card-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 0;
    transition: transform 0.4s ease;
  }

  .post-card:hover .card-img {
    transform: scale(1.06);
  }

  .card-img-placeholder {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, rgba(0, 100, 160, 0.3), rgba(0, 150, 100, 0.2));
  }

  .card-img-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(5, 20, 40, 0.55) 0%, transparent 60%);
    pointer-events: none;
  }

  .card-body {
    padding: 1.25em 1.4em 1.5em;
    display: flex;
    flex-direction: column;
    flex: 1;
    gap: 0.4em;
  }

  .card-date {
    font-size: 0.75rem;
    color: rgba(0, 212, 255, 0.65);
    font-weight: 500;
    margin: 0;
    letter-spacing: 0.03em;
  }

  .card-title {
    font-size: 1rem;
    font-weight: 700;
    line-height: 1.35;
    color: #e8f4fd;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card-desc {
    font-size: 0.82rem;
    color: rgba(138, 180, 204, 0.65);
    line-height: 1.55;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    flex: 1;
  }

  .card-cta {
    font-size: 0.8rem;
    font-weight: 600;
    color: rgba(0, 212, 255, 0.7);
    margin-top: 0.5em;
    transition: color 0.2s ease;
  }

  .post-card:hover .card-cta {
    color: #00ff9d;
    text-shadow: 0 0 8px rgba(0, 255, 157, 0.4);
  }

  /* ── Responsive ──────────────────────────────────────────────────────────── */
  @media (max-width: 900px) {
    .posts-grid { grid-template-columns: repeat(2, 1fr); }
    .post-card--featured {
      grid-column: 1 / -1;
      grid-template-columns: 1fr;
    }
    .post-card--featured .card-image-wrap { min-height: 220px; }
  }

  @media (max-width: 600px) {
    .posts-grid { grid-template-columns: 1fr; }
    .page-hero { padding: 3.5em 1.5em 2.5em; }
  }
</style>
