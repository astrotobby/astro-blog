---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import { getCollection } from 'astro:content';
import FormattedDate from '../components/FormattedDate.astro';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const featuredPost = posts[0];
const recentPosts = posts.slice(1, 4);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			.hero {
				padding: 6rem 1rem;
				text-align: center;
				background: linear-gradient(to bottom, #f8fafc, #ffffff);
			}
			.hero h1 {
				font-size: 4rem;
				margin-bottom: 1rem;
				color: #0f172a;
			}
			.hero p {
				font-size: 1.25rem;
				color: #475569;
				max-width: 600px;
				margin: 0 auto 2.5rem;
			}
			.hero-actions {
				display: flex;
				gap: 1rem;
				justify-content: center;
			}
			.btn {
				padding: 0.8rem 2rem;
				border-radius: 12px;
				font-weight: 600;
				transition: all 0.2s ease;
			}
			.btn-primary {
				background: #10b981;
				color: white;
			}
			.btn-primary:hover {
				background: #059669;
				transform: translateY(-2px);
				box-shadow: 0 10px 15px -3px rgba(16, 185, 129, 0.2);
			}
			.btn-secondary {
				background: #f1f5f9;
				color: #0f172a;
			}
			.btn-secondary:hover {
				background: #e2e8f0;
			}

			.section {
				max-width: 1100px;
				margin: 0 auto 6rem;
				padding: 0 1.5rem;
			}
			.section-title {
				font-size: 1.75rem;
				margin-bottom: 2rem;
				display: flex;
				justify-content: space-between;
				align-items: center;
			}
			.section-title a {
				font-size: 1rem;
				color: #10b981;
			}

			.featured-card {
				display: grid;
				grid-template-columns: 1fr 1fr;
				gap: 3rem;
				background: #ffffff;
				border-radius: 24px;
				padding: 2.5rem;
				border: 1px solid #f1f5f9;
				box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.05);
				transition: transform 0.3s ease;
			}
			.featured-card:hover {
				transform: translateY(-4px);
			}
			.featured-content {
				display: flex;
				flex-direction: column;
				justify-content: center;
			}
			.featured-image {
				width: 100%;
				height: 350px;
				object-fit: cover;
				border-radius: 16px;
			}

			.posts-grid {
				display: grid;
				grid-template-columns: repeat(3, 1fr);
				gap: 2rem;
			}
			.post-card {
				background: #ffffff;
				border-radius: 20px;
				overflow: hidden;
				border: 1px solid #f1f5f9;
				transition: all 0.3s ease;
			}
			.post-card:hover {
				transform: translateY(-5px);
				box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.05);
			}
			.post-image {
				width: 100%;
				height: 200px;
				object-fit: cover;
			}
			.post-content {
				padding: 1.5rem;
			}
			.post-date {
				font-size: 0.85rem;
				color: #10b981;
				font-weight: 600;
				margin-bottom: 0.5rem;
			}
			.post-title {
				font-size: 1.25rem;
				margin-bottom: 0.75rem;
				color: #0f172a;
			}
			.post-desc {
				font-size: 0.95rem;
				color: #64748b;
				line-height: 1.6;
			}

			.cta-banner {
				background: #10b981;
				border-radius: 32px;
				padding: 5rem 2rem;
				text-align: center;
				color: white;
				margin-bottom: 6rem;
			}
			.cta-banner h2 { color: white; font-size: 2.5rem; margin-bottom: 1rem; }
			.cta-banner p { color: rgba(255, 255, 255, 0.9); margin-bottom: 2.5rem; font-size: 1.1rem; }
			.cta-socials {
				display: flex;
				gap: 1.5rem;
				justify-content: center;
			}
			.cta-social-btn {
				background: rgba(255, 255, 255, 0.2);
				backdrop-filter: blur(10px);
				color: white;
				padding: 0.8rem 1.5rem;
				border-radius: 12px;
				font-weight: 600;
				display: flex;
				align-items: center;
				gap: 0.75rem;
				transition: all 0.2s ease;
			}
			.cta-social-btn:hover {
				background: white;
				color: #10b981;
				transform: translateY(-2px);
			}

			@media (max-width: 900px) {
				.featured-card { grid-template-columns: 1fr; gap: 1.5rem; padding: 1.5rem; }
				.posts-grid { grid-template-columns: repeat(2, 1fr); }
				.hero h1 { font-size: 2.5rem; }
			}
			@media (max-width: 600px) {
				.posts-grid { grid-template-columns: 1fr; }
				.cta-socials { flex-direction: column; }
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<h1>The Signal <span style="color: #10b981;">Through the Noise</span></h1>
				<p>Deep-dive analysis on AI agents, multi-agent systems, LLMs, and the technologies reshaping how we build, think, and create.</p>
				<div class="hero-actions">
					<a href="/blog" class="btn btn-primary">Explore Articles</a>
					<a href="/about" class="btn btn-secondary">About the Author</a>
				</div>
			</section>

			<section class="section">
				<div class="section-title">
					<h2>Featured Article</h2>
				</div>
				{featuredPost && (
					<a href={`/blog/${featuredPost.id}/`} class="featured-card">
						<img src={featuredPost.data.heroImage || '/blog-placeholder-about.jpg'} alt="" class="featured-image" />
						<div class="featured-content">
							<p class="post-date"><FormattedDate date={featuredPost.data.pubDate} /></p>
							<h3 class="post-title" style="font-size: 2rem;">{featuredPost.data.title}</h3>
							<p class="post-desc">{featuredPost.data.description}</p>
						</div>
					</a>
				)}
			</section>

			<section class="section">
				<div class="section-title">
					<h2>Recent Articles</h2>
					<a href="/blog">View All &rarr;</a>
				</div>
				<div class="posts-grid">
					{recentPosts.map((post) => (
						<a href={`/blog/${post.id}/`} class="post-card">
							<img src={post.data.heroImage || '/blog-placeholder-about.jpg'} alt="" class="post-image" />
							<div class="post-content">
								<p class="post-date"><FormattedDate date={post.data.pubDate} /></p>
								<h3 class="post-title">{post.data.title}</h3>
								<p class="post-desc">{post.data.description}</p>
							</div>
						</a>
					))}
				</div>
			</section>

			<section class="section">
				<div class="cta-banner">
					<h2>Stay Ahead of the Curve</h2>
					<p>Follow AstroSignal for weekly insights on AI, multi-agent systems, and emerging tech.</p>
					<div class="cta-socials">
						<a href="https://x.com/AstroboyTobby1" target="_blank" rel="noopener" class="cta-social-btn">
							<svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
							Follow on X
						</a>
						<a href="https://www.instagram.com/astro_tobby/" target="_blank" rel="noopener" class="cta-social-btn">
							<svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>
							Instagram
						</a>
						<a href="https://www.facebook.com/AstroteeSignal" target="_blank" rel="noopener" class="cta-social-btn">
							<svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path></svg>
							Facebook
						</a>
					</div>
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>
