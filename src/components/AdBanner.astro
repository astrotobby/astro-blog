---
interface Props {
	minHeight?: string;
	margin?: string;
}

const { minHeight = "90px", margin = "20px auto" } = Astro.props;
---

<!-- Ad removed as per priority fix #1 -->
<div class="ad-placeholder" style={`min-height: ${minHeight}; margin: ${margin};`}></div>

<style>
	.ad-placeholder {
		display: none;
	}
</style>
