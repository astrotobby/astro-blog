---
import HeaderLink from './HeaderLink.astro';
import { SITE_TITLE } from '../consts';
---

<header>
  <!-- Ambient glow line at the very top -->
  <div class="header-glow-bar"></div>

  <nav>
    <div class="nav-inner">
      <!-- Logo / Brand -->
      <a href="/" class="site-brand">
        <span class="brand-icon">
          <svg width="28" height="28" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg">
            <circle cx="14" cy="14" r="12" stroke="url(#brandGrad)" stroke-width="2"/>
            <path d="M8 14 L14 8 L20 14 L14 20 Z" fill="url(#brandGrad)" opacity="0.8"/>
            <circle cx="14" cy="14" r="3" fill="url(#brandGrad)"/>
            <defs>
              <linearGradient id="brandGrad" x1="0" y1="0" x2="28" y2="28" gradientUnits="userSpaceOnUse">
                <stop offset="0%" stop-color="#00d4ff"/>
                <stop offset="100%" stop-color="#00ff9d"/>
              </linearGradient>
            </defs>
          </svg>
        </span>
        <span class="brand-text">{SITE_TITLE}</span>
      </a>

      <!-- Nav links -->
      <div class="nav-links">
        <HeaderLink href="/">Home</HeaderLink>
        <HeaderLink href="/blog">Blog</HeaderLink>
        <HeaderLink href="/about">About</HeaderLink>
      </div>

      <!-- Social icons -->
      <div class="social-links">
        <a href="https://x.com/AstroboyTobby1" target="_blank" rel="noopener" aria-label="X (Twitter)">
          <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor">
            <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
          </svg>
        </a>
        <a href="https://www.instagram.com/astro_tobby/" target="_blank" rel="noopener" aria-label="Instagram">
          <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
            <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
            <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
          </svg>
        </a>
        <a href="https://www.facebook.com/AstroteeSignal" target="_blank" rel="noopener" aria-label="Facebook">
          <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor">
            <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path>
          </svg>
        </a>
      </div>
    </div>
  </nav>
</header>

<style>
  header {
    position: sticky;
    top: 0;
    z-index: 100;
    width: 100%;
  }

  .header-glow-bar {
    height: 2px;
    background: linear-gradient(90deg,
      transparent 0%,
      #00d4ff 25%,
      #00ff9d 50%,
      #00d4ff 75%,
      transparent 100%
    );
    background-size: 200% 100%;
    animation: glowBarSlide 4s linear infinite;
  }

  @keyframes glowBarSlide {
    0%   { background-position: 200% 0; }
    100% { background-position: -200% 0; }
  }

  nav {
    background: rgba(2, 11, 24, 0.82);
    backdrop-filter: blur(20px) saturate(1.5);
    -webkit-backdrop-filter: blur(20px) saturate(1.5);
    border-bottom: 1px solid rgba(0, 212, 255, 0.12);
    box-shadow: 0 4px 30px rgba(0, 0, 0, 0.4), 0 1px 0 rgba(0, 212, 255, 0.08);
  }

  .nav-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 1.5rem;
    height: 64px;
    display: flex;
    align-items: center;
    gap: 2rem;
  }

  /* ── Brand ── */
  .site-brand {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    text-decoration: none;
    flex-shrink: 0;
  }

  .brand-icon {
    display: flex;
    align-items: center;
    filter: drop-shadow(0 0 8px rgba(0, 212, 255, 0.6));
    transition: filter 0.3s ease;
  }
  .site-brand:hover .brand-icon {
    filter: drop-shadow(0 0 14px rgba(0, 255, 157, 0.8));
  }

  .brand-text {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 1.2rem;
    font-weight: 700;
    background: linear-gradient(135deg, #00d4ff, #00ff9d);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    letter-spacing: -0.02em;
  }

  /* ── Nav links ── */
  .nav-links {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    flex: 1;
  }

  .nav-links :global(a) {
    display: inline-block;
    padding: 0.4em 0.9em;
    border-radius: 8px;
    font-size: 0.95rem;
    font-weight: 500;
    color: rgba(232, 244, 253, 0.75);
    text-decoration: none;
    border: 1px solid transparent;
    transition: all 0.22s ease;
    letter-spacing: 0.01em;
  }

  .nav-links :global(a:hover),
  .nav-links :global(a.active) {
    color: #00d4ff;
    background: rgba(0, 212, 255, 0.08);
    border-color: rgba(0, 212, 255, 0.25);
    text-shadow: 0 0 12px rgba(0, 212, 255, 0.5);
    text-decoration: none;
  }

  .nav-links :global(a.active) {
    color: #00ff9d;
    background: rgba(0, 255, 157, 0.07);
    border-color: rgba(0, 255, 157, 0.25);
    text-shadow: 0 0 12px rgba(0, 255, 157, 0.5);
  }

  /* ── Social ── */
  .social-links {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-left: auto;
  }

  .social-links a {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 8px;
    color: rgba(138, 180, 204, 0.7);
    border: 1px solid rgba(0, 212, 255, 0.12);
    background: rgba(0, 212, 255, 0.04);
    transition: all 0.22s ease;
    text-decoration: none;
  }

  .social-links a:hover {
    color: #00d4ff;
    border-color: rgba(0, 212, 255, 0.4);
    background: rgba(0, 212, 255, 0.1);
    box-shadow: 0 0 16px rgba(0, 212, 255, 0.25);
    text-shadow: none;
  }

  @media (max-width: 720px) {
    .social-links { display: none; }
    .nav-inner { padding: 0 1rem; gap: 1rem; }
    .brand-text { font-size: 1rem; }
    .nav-links :global(a) { padding: 0.35em 0.6em; font-size: 0.875rem; }
  }
</style>
