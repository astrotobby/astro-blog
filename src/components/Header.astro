---
import HeaderLink from './HeaderLink.astro';
import { SITE_TITLE } from '../consts';
---

<header>
  <!-- Ambient glow line at the very top -->
  <div class="header-glow-bar"></div>

  <nav>
    <div class="nav-inner">
      <!-- Logo / Brand -->
      <a href="/" class="site-brand">
        <span class="brand-icon">
          <svg width="28" height="28" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg">
            <circle cx="14" cy="14" r="12" stroke="url(#brandGrad)" stroke-width="2"/>
            <path d="M8 14 L14 8 L20 14 L14 20 Z" fill="url(#brandGrad)" opacity="0.8"/>
            <circle cx="14" cy="14" r="3" fill="url(#brandGrad)"/>
            <defs>
              <linearGradient id="brandGrad" x1="0" y1="0" x2="28" y2="28" gradientUnits="userSpaceOnUse">
                <stop offset="0%" stop-color="#00d4ff"/>
                <stop offset="100%" stop-color="#00ff9d"/>
              </linearGradient>
            </defs>
          </svg>
        </span>
        <span class="brand-text">{SITE_TITLE}</span>
      </a>

      <!-- Nav links -->
      <div class="nav-links">
        <HeaderLink href="/">Home</HeaderLink>
        <HeaderLink href="/blog">Blog</HeaderLink>
        <HeaderLink href="/about">About</HeaderLink>
      </div>

      <!-- Social icons -->
      <div class="social-links">
        <a href="https://twitter.com/astrotobby" target="_blank" rel="noopener" aria-label="Twitter">
          <svg viewBox="0 0 16 16" width="20" height="20" fill="currentColor">
            <path d="M5.026 15c6.038 0 9.341-5.003 9.341-9.334 0-.14 0-.282-.006-.422A6.685 6.685 0 0 0 16 3.542a6.658 6.658 0 0 1-1.889.518 3.301 3.301 0 0 0 1.447-1.817 6.533 6.533 0 0 1-2.087.793A3.286 3.286 0 0 0 7.875 6.03a9.325 9.325 0 0 1-6.767-3.429 3.289 3.289 0 0 0 1.018 4.382A3.323 3.323 0 0 1 .64 6.575v.045a3.288 3.288 0 0 0 2.632 3.218 3.203 3.203 0 0 1-.865.115 3.23 3.23 0 0 1-.614-.057 3.283 3.283 0 0 0 3.067 2.277A6.588 6.588 0 0 1 .78 13.58a6.32 6.32 0 0 1-.78-.045A9.344 9.344 0 0 0 5.026 15z"/>
          </svg>
        </a>
        <a href="https://github.com/astrotobby" target="_blank" rel="noopener" aria-label="GitHub">
          <svg viewBox="0 0 16 16" width="20" height="20" fill="currentColor">
            <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"/>
          </svg>
        </a>
      </div>
    </div>
  </nav>
</header>

<style>
  header {
    position: sticky;
    top: 0;
    z-index: 100;
    width: 100%;
  }

  .header-glow-bar {
    height: 2px;
    background: linear-gradient(90deg,
      transparent 0%,
      #00d4ff 25%,
      #00ff9d 50%,
      #00d4ff 75%,
      transparent 100%
    );
    background-size: 200% 100%;
    animation: glowBarSlide 4s linear infinite;
  }

  @keyframes glowBarSlide {
    0%   { background-position: 200% 0; }
    100% { background-position: -200% 0; }
  }

  nav {
    background: rgba(2, 11, 24, 0.82);
    backdrop-filter: blur(20px) saturate(1.5);
    -webkit-backdrop-filter: blur(20px) saturate(1.5);
    border-bottom: 1px solid rgba(0, 212, 255, 0.12);
    box-shadow: 0 4px 30px rgba(0, 0, 0, 0.4), 0 1px 0 rgba(0, 212, 255, 0.08);
  }

  .nav-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 1.5rem;
    height: 64px;
    display: flex;
    align-items: center;
    gap: 2rem;
  }

  /* ── Brand ── */
  .site-brand {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    text-decoration: none;
    flex-shrink: 0;
  }

  .brand-icon {
    display: flex;
    align-items: center;
    filter: drop-shadow(0 0 8px rgba(0, 212, 255, 0.6));
    transition: filter 0.3s ease;
  }
  .site-brand:hover .brand-icon {
    filter: drop-shadow(0 0 14px rgba(0, 255, 157, 0.8));
  }

  .brand-text {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 1.2rem;
    font-weight: 700;
    background: linear-gradient(135deg, #00d4ff, #00ff9d);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    letter-spacing: -0.02em;
  }

  /* ── Nav links ── */
  .nav-links {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    flex: 1;
  }

  .nav-links :global(a) {
    display: inline-block;
    padding: 0.4em 0.9em;
    border-radius: 8px;
    font-size: 0.95rem;
    font-weight: 500;
    color: rgba(232, 244, 253, 0.75);
    text-decoration: none;
    border: 1px solid transparent;
    transition: all 0.22s ease;
    letter-spacing: 0.01em;
  }

  .nav-links :global(a:hover),
  .nav-links :global(a.active) {
    color: #00d4ff;
    background: rgba(0, 212, 255, 0.08);
    border-color: rgba(0, 212, 255, 0.25);
    text-shadow: 0 0 12px rgba(0, 212, 255, 0.5);
    text-decoration: none;
  }

  .nav-links :global(a.active) {
    color: #00ff9d;
    background: rgba(0, 255, 157, 0.07);
    border-color: rgba(0, 255, 157, 0.25);
    text-shadow: 0 0 12px rgba(0, 255, 157, 0.5);
  }

  /* ── Social ── */
  .social-links {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-left: auto;
  }

  .social-links a {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 8px;
    color: rgba(138, 180, 204, 0.7);
    border: 1px solid rgba(0, 212, 255, 0.12);
    background: rgba(0, 212, 255, 0.04);
    transition: all 0.22s ease;
    text-decoration: none;
  }

  .social-links a:hover {
    color: #00d4ff;
    border-color: rgba(0, 212, 255, 0.4);
    background: rgba(0, 212, 255, 0.1);
    box-shadow: 0 0 16px rgba(0, 212, 255, 0.25);
    text-shadow: none;
  }

  @media (max-width: 720px) {
    .social-links { display: none; }
    .nav-inner { padding: 0 1rem; gap: 1rem; }
    .brand-text { font-size: 1rem; }
    .nav-links :global(a) { padding: 0.35em 0.6em; font-size: 0.875rem; }
  }
</style>
