---
import HeaderLink from './HeaderLink.astro';
import { SITE_TITLE } from '../consts';
---

<header>
  <nav>
    <div class="nav-inner">
      <a href="/" class="site-brand">
        <span class="brand-text">{SITE_TITLE}</span>
      </a>

      <div class="nav-links">
        <HeaderLink href="/">Home</HeaderLink>
        <HeaderLink href="/blog">Blog</HeaderLink>
        <HeaderLink href="/about">About</HeaderLink>
      </div>

      <div class="social-links">
        <a href="https://x.com/AstroboyTobby1" target="_blank" rel="noopener" aria-label="X">
          <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
        </a>
        <a href="https://www.instagram.com/astro_tobby/" target="_blank" rel="noopener" aria-label="Instagram">
          <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>
        </a>
      </div>
    </div>
  </nav>
</header>

<style>
  header {
    background: #FFFFFF;
    border-bottom: 1px solid rgba(0, 0, 0, 0.06);
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .nav-inner {
    max-width: 1000px;
    margin: 0 auto;
    padding: 0 1.5rem;
    height: 80px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .brand-text {
    font-size: 1.5rem;
    font-weight: 800;
    color: #1A1A1A;
    letter-spacing: -0.02em;
  }

  .nav-links {
    display: flex;
    gap: 0.5rem;
  }

  .nav-links :global(a) {
    color: #4A5568;
    font-weight: 500;
    padding: 0.5rem 1rem;
    border-radius: 6px;
    transition: all 0.2s ease;
  }

  .nav-links :global(a:hover) {
    color: #4F46E5;
    background: rgba(79, 70, 229, 0.05);
  }

  .nav-links :global(a.active) {
    color: #4F46E5;
    font-weight: 700;
  }

  .social-links {
    display: flex;
    gap: 1.25rem;
  }

  .social-links a {
    color: #718096;
    transition: color 0.2s ease;
  }

  .social-links a:hover {
    color: #4F46E5;
  }

  @media (max-width: 768px) {
    .nav-inner { height: 70px; }
    .social-links { display: none; }
  }
</style>
