---
const today = new Date();
---
<footer>
  <div class="footer-inner">
    <div class="footer-brand">
      <span class="footer-brand-name">Astro Tobby</span>
      <p class="footer-tagline">Navigating the frontier of AI, technology, and the future.</p>
    </div>
    <div class="footer-links-group">
      <h4>Navigate</h4>
      <a href="/">Home</a>
      <a href="/blog">Blog</a>
      <a href="/about">About</a>
    </div>
    <div class="footer-links-group">
      <h4>Legal</h4>
      <a href="/privacy-policy">Privacy Policy</a>
    </div>
    <div class="footer-links-group">
      <h4>Connect</h4>
      <div class="footer-social-vertical">
        <a href="https://x.com/AstroboyTobby1" target="_blank" rel="noopener" aria-label="X">
          <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          <span>X (Twitter)</span>
        </a>
        <a href="https://www.instagram.com/astro_tobby/" target="_blank" rel="noopener" aria-label="Instagram">
          <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>
          <span>Instagram</span>
        </a>
        <a href="https://www.facebook.com/AstroteeSignal" target="_blank" rel="noopener" aria-label="Facebook">
          <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path></svg>
          <span>Facebook</span>
        </a>
      </div>
    </div>
  </div>
  <div class="footer-bottom">
    <p>&copy; {today.getFullYear()} Astro Tobby. Built for the future.</p>
  </div>
</footer>
<style>
  footer {
    background: linear-gradient(180deg, #FFFFFF 0%, #F9FAFB 100%);
    border-top: 1px solid rgba(0, 0, 0, 0.06);
    padding: 5rem 0 3rem;
    margin-top: 8rem;
  }
  
  .footer-inner {
    max-width: 1000px;
    margin: 0 auto;
    padding: 0 1.5rem;
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr;
    gap: 4rem;
  }
  
  .footer-brand-name {
    font-size: 1.25rem;
    font-weight: 800;
    background: linear-gradient(135deg, #0F172A 0%, #4F46E5 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    display: block;
    margin-bottom: 1rem;
  }
  
  .footer-tagline {
    font-size: 0.95rem;
    color: #4A5568;
    line-height: 1.6;
    max-width: 320px;
  }
  
  .footer-links-group h4 {
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: #718096;
    margin-bottom: 1.5rem;
  }
  
  .footer-links-group a {
    display: block;
    font-size: 0.95rem;
    color: #4A5568;
    margin-bottom: 0.85rem;
    transition: all 0.2s ease;
    position: relative;
    padding-left: 0;
  }
  
  .footer-links-group a::before {
    content: '';
    position: absolute;
    left: 0;
    width: 0;
    height: 2px;
    background: #4F46E5;
    transition: width 0.3s ease;
    bottom: -2px;
  }
  
  .footer-links-group a:hover {
    color: #4F46E5;
  }
  
  .footer-links-group a:hover::before {
    width: 100%;
  }
  
  .footer-social-vertical {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  
  .footer-social-vertical a {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    color: #4A5568;
    text-decoration: none;
    font-size: 0.95rem;
    transition: all 0.2s ease;
    padding: 0.5rem;
    border-radius: 8px;
    margin-left: -0.5rem;
  }
  
  .footer-social-vertical a:hover {
    color: #4F46E5;
    background: rgba(79, 70, 229, 0.05);
    transform: translateX(4px);
  }
  
  .footer-bottom {
    max-width: 1000px;
    margin: 4rem auto 0;
    padding: 2.5rem 1.5rem 0;
    border-top: 1px solid rgba(0, 0, 0, 0.04);
    text-align: center;
  }
  
  .footer-bottom p {
    font-size: 0.9rem;
    color: #718096;
  }
  
  @media (max-width: 900px) {
    .footer-inner { 
      grid-template-columns: 1fr 1fr; 
      gap: 3rem; 
    }
    .footer-brand { 
      grid-column: 1 / -1; 
    }
  }
  
  @media (max-width: 600px) {
    .footer-inner { 
      grid-template-columns: 1fr; 
      gap: 2.5rem; 
    }
  }
</style>
