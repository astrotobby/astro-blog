<style>
  footer {
    background: linear-gradient(180deg, #FFFFFF 0%, #F9FAFB 100%);
    border-top: 1px solid rgba(0, 0, 0, 0.06);
    padding: 5rem 0 3rem;
    margin-top: 8rem;
  }
  
  .footer-inner {
    max-width: 1000px;
    margin: 0 auto;
    padding: 0 1.5rem;
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr;
    gap: 4rem;
  }
  
  .footer-brand-name {
    font-size: 1.25rem;
    font-weight: 800;
    background: linear-gradient(135deg, #0F172A 0%, #4F46E5 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    display: block;
    margin-bottom: 1rem;
  }
  
  .footer-tagline {
    font-size: 0.95rem;
    color: #4A5568;
    line-height: 1.6;
    max-width: 320px;
  }
  
  .footer-links-group h4 {
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: #718096;
    margin-bottom: 1.5rem;
  }
  
  .footer-links-group a {
    display: block;
    font-size: 0.95rem;
    color: #4A5568;
    margin-bottom: 0.85rem;
    transition: all 0.2s ease;
    position: relative;
    padding-left: 0;
  }
  
  .footer-links-group a::before {
    content: '';
    position: absolute;
    left: 0;
    width: 0;
    height: 2px;
    background: #4F46E5;
    transition: width 0.3s ease;
    bottom: -2px;
  }
  
  .footer-links-group a:hover {
    color: #4F46E5;
  }
  
  .footer-links-group a:hover::before {
    width: 100%;
  }
  
  .footer-social-horizontal {
    display: flex;
    flex-direction: row;
    gap: 1rem;
    flex-wrap: wrap;
  }
  
  .footer-social-horizontal a {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    color: #4A5568;
    text-decoration: none;
    transition: all 0.2s ease;
    border-radius: 8px;
    background: rgba(0, 0, 0, 0.02);
  }
  
  .footer-social-horizontal a:hover {
    color: #4F46E5;
    background: rgba(79, 70, 229, 0.08);
    transform: translateY(-2px);
  }
  
  .footer-bottom {
    max-width: 1000px;
    margin: 4rem auto 0;
    padding: 2.5rem 1.5rem 0;
    border-top: 1px solid rgba(0, 0, 0, 0.04);
    text-align: center;
  }
  
  .footer-bottom p {
    font-size: 0.9rem;
    color: #718096;
  }
  
  @media (max-width: 900px) {
    .footer-inner { 
      grid-template-columns: 1fr 1fr; 
      gap: 3rem; 
    }
    .footer-brand { 
      grid-column: 1 / -1; 
    }
  }
  
  @media (max-width: 600px) {
    .footer-inner { 
      grid-template-columns: 1fr; 
      gap: 2.5rem; 
    }
  }
</style>
